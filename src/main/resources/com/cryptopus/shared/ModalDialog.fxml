<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    Modal dialog. Root is a full-bleed StackPane that acts as the dim
    backdrop; the card sits centered above it and reuses the existing
    `main-card` style so it visually matches the rest of the app.
-->
<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.cryptopus.shared.modal.ModalDialogController"
           fx:id="backdrop"
           styleClass="modal-backdrop"
           alignment="CENTER">

    <VBox fx:id="card"
          styleClass="main-card"
          spacing="20"
          maxWidth="700"
          maxHeight="-Infinity">
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <!-- Header: optional icon + title/message column -->
        <HBox fx:id="headerRow" spacing="20" alignment="CENTER_LEFT">
            <ImageView fx:id="iconView"
                       fitWidth="70"
                       preserveRatio="true"
                       visible="false"
                       managed="false"/>
            <VBox spacing="20" HBox.hgrow="ALWAYS">
                <Label fx:id="titleLabel"
                       text=""
                       styleClass="heading-lg"
                       wrapText="true"/>
                <Label fx:id="messageLabel"
                       text=""
                       styleClass="text-md"
                       wrapText="true"/>
            </VBox>
        </HBox>

        <!-- Footer: optional secondary + primary button -->
        <HBox spacing="20" alignment="CENTER_RIGHT">
            <VBox.margin>
                <Insets top="20"/>
            </VBox.margin>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="secondaryButton"
                    text=""
                    prefWidth="170"
                    visible="false"
                    managed="false"
                    styleClass="secondary-button"/>
            <Button fx:id="primaryButton"
                    text=""
                    prefWidth="170"
                    styleClass="primary-button"/>
        </HBox>
    </VBox>
</StackPane>